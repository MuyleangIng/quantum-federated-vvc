__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Pytest ─────────────────────────────────────────────────────
.pytest_cache/
.cache/
*.pytest_ini

# ── Jupyter ────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Gurobi license (sensitive) ─────────────────────────────────
gurobi.lic

# ── OS files ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Build / dist ───────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/

